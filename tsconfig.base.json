{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "preserve",
    "paths": {
      "@ministack-ui/shared": ["./packages/shared/src/index.ts"],
      "@ministack-ui/ui": ["./packages/ui/src/index.ts"],
      "@ministack-ui/runtime-sdk": ["./packages/runtime-sdk/src/index.ts"],
      "@ministack-ui/log-engine": ["./packages/log-engine/src/index.ts"],
      "@ministack-ui/event-engine": ["./packages/event-engine/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
