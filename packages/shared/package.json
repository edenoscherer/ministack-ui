{
  "name": "@ministack/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared base types and side-effect-free utilities for MiniStack UI",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@ministack/eslint-config": "workspace:*",
    "eslint": "^9.11.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
