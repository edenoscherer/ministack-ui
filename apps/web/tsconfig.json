{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@ministack-ui/shared": ["../../packages/shared/src/index.ts"],
      "@ministack-ui/ui": ["../../packages/ui/src/index.ts"],
      "@ministack-ui/runtime-sdk": ["../../packages/runtime-sdk/src/index.ts"],
      "@ministack-ui/log-engine": ["../../packages/log-engine/src/index.ts"],
      "@ministack-ui/event-engine": ["../../packages/event-engine/src/index.ts"]
    },
    "noEmit": true,
    "incremental": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
